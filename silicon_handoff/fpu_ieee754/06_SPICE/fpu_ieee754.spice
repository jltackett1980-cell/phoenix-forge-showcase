.subckt AND2 A B Y
B_AND internal 0 V=0.5*(tanh(20*(V(A)-0.5))+1)*(tanh(20*(V(B)-0.5))+1)
R_out internal Y 1
R_pull Y 0 100k
C_load Y 0 10f
.ends

.subckt ANDN2 A B Y
B_ANDN internal 0 V=0.5*(tanh(20*(V(A)-0.5))+1)*(1-0.5*(tanh(20*(V(B)-0.5))+1))
R_out internal Y 1
R_pull Y 0 100k
C_load Y 0 10f
.ends

.subckt CELL_DFFE_PN0 A B Y
